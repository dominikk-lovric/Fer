        MOV SP, #0x10000
        LDR R9, CITAJ
        LDR R1, PISI

loop
        LDR R2, [R9], #4
        LDR R3, KR__
        CMP R2, R3
        BEQ kraj
        LDR R3, [R9], #4
        LDR R4, [R9], #4
        CMP R2, #0
        BEQ zbraj
        CMP R2, #1
        BEQ oduz
        CMP R2, #2
        BEQ mult
        CMP R2, #3
        BEQ dijel
        B loop
zbraj
        ADD R5,R3,R4
        B spremi
oduz
        SUB R5,R3,R4
        B spremi
mult
        EOR R6, R3, R4
        CMP R3, #0
        RSBLT R3, R3, #0
        CMP R4, #0
        RSBLT R4, R4, #0
        MUL R5,R3,R4
        CMP R6, #0
        BGE spremi
        RSB R5,R5,#0
        B spremi
dijel
        STMFD SP!, {R3, R4}
        BL DIJELI
        ADD SP, SP, #8
        MOV R5, R0
        B spremi
DIJELI
        STMFD SP!, {R4-R8, LR}
        LDR R4, [SP, #24]
        LDR R5, [SP, #28]
        CMP R5, #0
        BNE nnula
        MOV R0,#0
        B dk
nnula
        EOR R6,R4,R5
        MOV R7, #0
        CMP R4, #0
        RSBLT R4,R4,#0
        CMP R5, #0
        RSBLT R5,R5, #0
dlop
        CMP R4,R5
        BLT dlk
        SUB R4,R4,R5
        ADD R7,R7,#1
        B dlop
dlk
        MOV R0,R7
        CMP R6,#0
        BGE dk
        RSB R0,R0,#0
dk
        LDMFD SP!, {R4-R8,PC}
spremi
        STR R5, [R1], #4
        B loop
kraj
        LDR R2, ZAK
        STR R2, [R1]
        SWI 123456
CITAJ   DW 0x700 
PISI    DW 0x2000
KR__    DW 0x80808080
ZAK     DW 0xFFFFFFFF
        ORG 0x700
        DW 0x3, 0xFFFFFEFF, 0x00000010
        DW 0x1, 0x1F4, 0xFFFFFD44
        DW 0x2, 0xFFFFFFFE, 0xA
        DW 0x3, 0xFFFFF000, 0xFFFFFFC0
        DW 0x80808080
        ORG 0x2000
        DW 0,0,0,0,0